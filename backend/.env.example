# Application
NODE_ENV=development
PORT=3000
APP_NAME="Restaurant Ops API"
APP_VERSION=1.0.0
APP_URL=http://localhost:3000

# Database (PostgreSQL)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/restaurant_ops?schema=public
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# JWT
JWT_SECRET=change-this-to-a-very-long-random-secret-in-production-min-32-chars
JWT_EXPIRES_IN=24h
JWT_REFRESH_SECRET=change-this-to-another-very-long-random-secret-min-32-chars
JWT_REFRESH_EXPIRES_IN=7d

# CORS
CORS_ORIGIN=http://localhost:3000,http://localhost:3001

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# File uploads
UPLOAD_MAX_SIZE_MB=10
UPLOAD_DIR=./uploads
UPLOAD_BASE_URL=http://localhost:3000/uploads

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@example.com
SMTP_PASSWORD=your-smtp-password
SMTP_FROM_NAME="Restaurant Ops"
SMTP_FROM_EMAIL=noreply@restaurant-ops.com

# Push notifications (FCM)
FCM_SERVER_KEY=
FCM_PROJECT_ID=

# AI providers
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
AI_DEFAULT_PROVIDER=openai
AI_TIMEOUT_MS=30000

# Logging
LOG_LEVEL=info
LOG_DIR=./logs

# Audit image storage
AUDIT_IMAGE_BUCKET=restaurant-audits
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
