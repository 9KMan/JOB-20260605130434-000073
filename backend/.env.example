# Server
NODE_ENV=development
PORT=4000
LOG_LEVEL=info

# Database
DATABASE_URL=postgres://postgres:postgres@localhost:5432/restaurant_ops
DB_SSL=false

# JWT
JWT_SECRET=replace-me-with-a-long-random-string
JWT_EXPIRES_IN=8h

# AI Providers
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
AI_PROVIDER=openai
AI_TIMEOUT_MS=30000
AI_MAX_RETRIES=3

# Vector / RAG
RAG_CHUNK_SIZE=800
RAG_CHUNK_OVERLAP=120
RAG_TOP_K=5

# Alerts
ALERT_WEBHOOK_URL=
ALERT_SLACK_WEBHOOK_URL=
ALERT_EMAIL_FROM=alerts@restaurant-ops.local
